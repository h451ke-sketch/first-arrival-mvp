# Copy this file to .env and fill in real keys.
# Expo will inline EXPO_PUBLIC_* variables into the JS bundle at build time.
# WARNING: any EXPO_PUBLIC_* value ends up shipped in client code; do not put
# server-only secrets here. Use a backend proxy for those.

# Deepgram (Speech-to-Text + Text-to-Speech)
# https://console.deepgram.com/
EXPO_PUBLIC_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# DeepSeek (NPC dialogue + summary)
# https://platform.deepseek.com/
EXPO_PUBLIC_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini (optional, currently unused fallback)
# https://aistudio.google.com/
EXPO_PUBLIC_GEMINI_API_KEY=
